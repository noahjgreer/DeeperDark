{
	"schemaVersion": 1,
	"id": "deeperdark",
	"version": "${version}",
	"name": "Deeperdark",
	"description": "The deep dark is always below you.",
	"authors": [
		"FinniTheFox"
	],
	"contact": {
		"homepage": "https://noahsarch.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/deeperdark/icon.png",
	"environment": "*",
	"accessWidener": "seasons.accesswidener",
	"entrypoints": {
		"main": [
			"net.noahsarch.deeperdark.Deeperdark",
			"io.github.lucaargolo.seasons.FabricSeasons"
		],
		"client": [
			"net.noahsarch.deeperdark.DeeperDarkClient",
			"io.github.lucaargolo.seasons.FabricSeasonsClient"
		],
		"lambdynlights:initializer": [
			"net.noahsarch.deeperdark.compat.DeeperDarkDynamicLightsInit"
		]
	},
	"mixins": [
		"deeperdark.mixins.json",
		"seasons.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	},
	"suggests": {
		"lambdynlights": ">=4.0.0"
	}
}