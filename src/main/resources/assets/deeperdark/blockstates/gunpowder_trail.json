{
  "multipart": [
    {
      "when": {
        "OR": [
          { "east": "none", "north": "none", "south": "none", "west": "none" },
          { "east": "side|up", "north": "side|up" },
          { "east": "side|up", "south": "side|up" },
          { "south": "side|up", "west": "side|up" },
          { "north": "side|up", "west": "side|up" }
        ]
      },
      "apply": { "model": "deeperdark:block/gunpowder_trail_dot" }
    },
    {
      "when": { "north": "side|up" },
      "apply": { "model": "deeperdark:block/gunpowder_trail_side0" }
    },
    {
      "when": { "south": "side|up" },
      "apply": { "model": "deeperdark:block/gunpowder_trail_side_alt0" }
    },
    {
      "when": { "east": "side|up" },
      "apply": { "model": "deeperdark:block/gunpowder_trail_side_alt1", "y": 270 }
    },
    {
      "when": { "west": "side|up" },
      "apply": { "model": "deeperdark:block/gunpowder_trail_side1", "y": 270 }
    },
    {
      "when": { "north": "up" },
      "apply": { "model": "deeperdark:block/gunpowder_trail_up" }
    },
    {
      "when": { "east": "up" },
      "apply": { "model": "deeperdark:block/gunpowder_trail_up", "y": 90 }
    },
    {
      "when": { "south": "up" },
      "apply": { "model": "deeperdark:block/gunpowder_trail_up", "y": 180 }
    },
    {
      "when": { "west": "up" },
      "apply": { "model": "deeperdark:block/gunpowder_trail_up", "y": 270 }
    }
  ]
}
